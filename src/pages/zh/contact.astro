---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, translatePath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  currentPath={Astro.url.pathname}
  title={t('nav.contact')}
  description={t('contact.subtitle')}
>
  <section class="border-b border-surface-800/30">
    <div class="container-page py-16 sm:py-20">
      <div class="tag mb-4">{t('footer.contact')}</div>
      <h1 class="text-4xl font-extrabold tracking-tight">
        {t('contact.title').split(' ').slice(0, -1).join(' ')} <span class="text-gradient">{t('contact.title').split(' ').slice(-1)}</span>
      </h1>
      <p class="text-surface-400 text-lg mt-4 max-w-2xl">
        {t('contact.subtitle')}
      </p>
    </div>
  </section>

  <section class="container-page py-16 sm:py-20">
    <div class="grid lg:grid-cols-5 gap-12">
      <!-- Contact Form -->
      <div class="lg:col-span-3">
        <h2 class="text-2xl font-bold text-white mb-2">{t('nav.sendInquiry')}</h2>
        <p class="text-surface-400 text-sm mb-8">{t('contact.sidebar.responseDesc')}</p>

        <form id="inquiry-form" class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm text-surface-300 mb-2">{t('contact.form.name')} <span class="text-red-400">*</span></label>
              <input type="text" name="name" required placeholder={t('contact.form.name')} class="input-field" />
            </div>
            <div>
              <label class="block text-sm text-surface-300 mb-2">{t('contact.form.company')}</label>
              <input type="text" name="company" placeholder={t('contact.form.company')} class="input-field" />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm text-surface-300 mb-2">{t('contact.form.email')} <span class="text-red-400">*</span></label>
              <input type="email" name="email" required placeholder={t('contact.form.email')} class="input-field" />
            </div>
            <div>
              <label class="block text-sm text-surface-300 mb-2">{t('contact.sidebar.phone')} / WhatsApp</label>
              <input type="tel" name="phone" placeholder="+Country code and number" class="input-field" />
            </div>
          </div>

          <div>
            <label class="block text-sm text-surface-300 mb-2">{t('contact.form.product')}</label>
            <select name="product" class="input-field">
              <option value="">{t('contact.form.product.placeholder')}</option>
              <option value="INS">{t('contact.form.product.ins')}</option>
              <option value="Gyroscopes">{t('contact.form.product.gyro')}</option>
              <option value="Fiber">{t('contact.form.product.fiber')}</option>
              <option value="IMU">Inertial Measurement Units</option>
              <option value="Accelerometers">Accelerometers</option>
              <option value="Calibration">Calibration Equipment</option>
              <option value="Anti-Jamming">Anti-Jamming Communication</option>
              <option value="Other">{t('contact.form.product.other')}</option>
            </select>
          </div>

          <div>
            <label class="block text-sm text-surface-300 mb-2">{t('contact.form.industry')}</label>
            <select name="industry" class="input-field">
              <option value="">{t('contact.form.industry.placeholder')}</option>
              <option value="Aerospace">{t('contact.form.industry.aerospace')}</option>
              <option value="Marine">{t('contact.form.industry.marine')}</option>
              <option value="Autonomous">{t('contact.form.industry.autonomous')}</option>
              <option value="Surveying">{t('contact.form.industry.surveying')}</option>
              <option value="Power">{t('home.industries.electric')}</option>
              <option value="Transport">{t('home.industries.transportation')}</option>
              <option value="Defense">{t('contact.form.industry.defense')}</option>
              <option value="Other">{t('contact.form.industry.other')}</option>
            </select>
          </div>

          <div>
            <label class="block text-sm text-surface-300 mb-2">{t('contact.form.message')} <span class="text-red-400">*</span></label>
            <textarea name="message" required rows="5" placeholder={t('contact.form.message.placeholder')} class="input-field resize-none"></textarea>
          </div>

          <button type="submit" class="btn-primary text-base w-full justify-center">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            {t('contact.form.submit')}
          </button>

          <p id="form-success" class="hidden text-center text-green-400 text-sm py-4 bg-green-500/10 rounded-lg border border-green-500/20">
            {t('contact.form.success')}
          </p>
          <p id="form-error" class="hidden text-center text-red-400 text-sm py-4 bg-red-500/10 rounded-lg border border-red-500/20">
            {t('contact.form.error')}
          </p>
        </form>
      </div>

      <!-- Contact Info Sidebar -->
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-bold text-white mb-6">{t('contact.sidebar.title')}</h2>

        <div class="space-y-6">
          <div class="glass-card p-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-green-500/10 flex items-center justify-center text-green-400 flex-shrink-0">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
              </div>
              <div>
                <div class="text-sm font-medium text-white">{t('contact.sidebar.whatsapp')}</div>
                <a href="https://wa.me/8618062673472" class="text-brand-400 text-sm font-mono hover:text-brand-300 transition-colors" target="_blank">+86 180 6267 3472</a>
                <p class="text-surface-500 text-xs mt-1">Preferred for quick inquiries</p>
              </div>
            </div>
          </div>

          <div class="glass-card p-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-brand-500/10 flex items-center justify-center text-brand-400 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <div class="text-sm font-medium text-white">{t('contact.sidebar.email')}</div>
                <a href="mailto:yaw_chan@liocrebif.com.cn" class="text-brand-400 text-sm font-mono hover:text-brand-300 transition-colors">yaw_chan@liocrebif.com.cn</a>
                <p class="text-surface-500 text-xs mt-1">For detailed technical inquiries</p>
              </div>
            </div>
          </div>

          <div class="glass-card p-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-surface-700/50 flex items-center justify-center text-surface-300 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <div class="text-sm font-medium text-white">{t('contact.sidebar.phone')}</div>
                <a href="tel:+8618062673472" class="text-brand-400 text-sm font-mono hover:text-brand-300 transition-colors">+86 180 6267 3472</a>
                <p class="text-surface-500 text-xs mt-1">Available 24/7 for urgent matters</p>
              </div>
            </div>
          </div>

          <div class="glass-card p-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-surface-700/50 flex items-center justify-center text-surface-300 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <div class="text-sm font-medium text-white">{t('contact.sidebar.address')}</div>
                <p class="text-surface-400 text-sm mt-1">Office Unit B ON 9/F<br/>Thomson Commercial Building<br/>8 Thomson Road<br/>Hong Kong</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Response Time Card -->
        <div class="mt-6 glass-card p-5 text-center bg-brand-500/5 border-brand-500/20">
          <div class="text-3xl font-black text-brand-400">{t('contact.sidebar.response')}</div>
          <div class="text-sm text-surface-400 mt-1">{t('contact.sidebar.response')}</div>
          <p class="text-surface-500 text-xs mt-2">{t('contact.sidebar.responseDesc')}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('inquiry-form');
  const success = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');

  // Replace YOUR_FORM_ID with your Formspree form ID
  // Get one free at: https://formspree.io (30 seconds)
  const FORMSPREE_ID = 'xjgdjndg';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    // If Formspree not configured yet, use mailto fallback
    if (FORMSPREE_ID === 'YOUR_FORM_ID') {
      const subject = encodeURIComponent('Product Inquiry - ' + (data.get('product') || 'General'));
      const body = encodeURIComponent(
        'Name: ' + data.get('name') + '\n' +
        'Company: ' + data.get('company') + '\n' +
        'Email: ' + data.get('email') + '\n' +
        'Phone: ' + data.get('phone') + '\n' +
        'Product: ' + data.get('product') + '\n' +
        'Industry: ' + data.get('industry') + '\n\n' +
        'Message:\n' + data.get('message')
      );
      window.location.href = 'mailto:yaw_chan@liocrebif.com.cn?subject=' + subject + '&body=' + body;
      form.reset();
      success?.classList.remove('hidden');
      return;
    }

    try {
      const res = await fetch('https://formspree.io/f/' + FORMSPREE_ID, {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' }
      });

      if (res.ok) {
        form.reset();
        success?.classList.remove('hidden');
        errorEl?.classList.add('hidden');
      } else {
        errorEl?.classList.remove('hidden');
        success?.classList.add('hidden');
      }
    } catch {
      errorEl?.classList.remove('hidden');
      success?.classList.add('hidden');
    }
  });
</script>
