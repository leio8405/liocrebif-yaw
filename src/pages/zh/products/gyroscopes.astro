---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, translatePath } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  currentPath={Astro.url.pathname}
  title={t('products.gyro.pageTitle')}
  description={t('products.gyro.pageDesc')}
>
  <section class="border-b border-surface-800/30">
    <div class="container-page py-16 sm:py-20">
      <a href={translatePath('/products', lang)} class="text-surface-500 hover:text-surface-300 text-sm transition-colors mb-4 inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> {t('nav.products')}
      </a>
      <h1 class="text-4xl font-extrabold tracking-tight">{t('products.gyro.pageTitle').split(' ').slice(0, -1).join(' ')} <span class="text-gradient">{t('products.gyro.pageTitle').split(' ').slice(-1)}</span></h1>
      <p class="text-surface-400 text-lg mt-4 max-w-2xl">{t('products.gyro.pageDesc')}</p>
    </div>
  </section>

  <section class="container-page py-16">
    <div class="space-y-10">

      <!-- LKF-FS60 -->
      <div class="glass-card overflow-hidden">
        <div class="grid lg:grid-cols-3">
          <div class="lg:col-span-1 bg-surface-900/50 flex items-center justify-center p-6 min-h-[240px]">
            <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/10/30/b17433d3ad3d413380bbdb2ed6a5c43e.png" alt="LKF-FS60 Single Axis Medium-High Precision FOG" class="max-h-[200px] object-contain" loading="lazy" />
          </div>
          <div class="lg:col-span-2 p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-2">
              <span class="tag">{t('home.tech.gyro.tag1')}</span><span class="text-xs text-surface-500 font-mono">LKF-FS60</span>
            </div>
            <h3 class="text-xl font-bold text-white">{t('home.featured.fs60.title')}</h3>
            <p class="text-surface-400 text-sm mt-2">{t('home.featured.fs60.desc')}</p>
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="text-xs text-surface-500">{t('products.size')}: 6×6×3 cm | RS-422 Digital Output</span>
            </div>
            <div class="flex flex-wrap gap-3 mt-4">
              <span class="tag">Electro-optical Pod</span><span class="tag">Flight Control</span><span class="tag">Platform Stabilizer</span><span class="tag">Light UAV</span>
            </div>
            <a href={translatePath('/contact', lang)} class="btn-primary text-sm mt-4">{t('products.requestDatasheet')}</a>
          </div>
        </div>
      </div>

      <!-- LKF-FS50A/X -->
      <div class="glass-card overflow-hidden">
        <div class="grid lg:grid-cols-3">
          <div class="lg:col-span-1 bg-surface-900/50 flex items-center justify-center p-6 min-h-[240px]">
            <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/26/86c40da8a47542398ab60942bda42052.png" alt="LKF-FS50A/X Single Axis Medium-Low Precision FOG" class="max-h-[200px] object-contain" loading="lazy" />
          </div>
          <div class="lg:col-span-2 p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-2">
              <span class="tag">{t('home.tech.gyro.tag1')}</span><span class="text-xs text-surface-500 font-mono">LKF-FS50A/X</span>
            </div>
            <h3 class="text-xl font-bold text-white">Single Axis Medium-Low Precision FOG</h3>
            <p class="text-surface-400 text-sm mt-2">Compact closed-loop FOG with breakthrough miniaturized design. 135μm thin PM fiber technology reduces coil size. Pure solid-state, high reliability, ideal for medium-low precision inertial navigation and control applications.</p>
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="text-xs text-surface-500">{t('products.size')}: 5×5×3.65 cm | RS-422 Digital Output</span>
            </div>
            <div class="flex flex-wrap gap-3 mt-4">
              <span class="tag">Optical Platform</span><span class="tag">Satcom on the Move</span><span class="tag">IMU</span><span class="tag">Light UAV</span>
            </div>
            <a href={translatePath('/contact', lang)} class="btn-primary text-sm mt-4">{t('products.requestDatasheet')}</a>
          </div>
        </div>
      </div>

      <!-- LKF-F3X90 -->
      <div class="glass-card overflow-hidden">
        <div class="grid lg:grid-cols-3">
          <div class="lg:col-span-1 bg-surface-900/50 flex items-center justify-center p-6 min-h-[240px]">
            <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/10/31/615113fbaf064eb197b770d9ec6da6e2.png" alt="LKF-F3X90 Three-Axis High Precision FOG" class="max-h-[200px] object-contain" loading="lazy" />
          </div>
          <div class="lg:col-span-2 p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-2">
              <span class="tag">FOG IMU</span><span class="text-xs text-surface-500 font-mono">LKF-F3X90</span>
            </div>
            <h3 class="text-xl font-bold text-white">Three-Axis High Precision FOG IMU</h3>
            <p class="text-surface-400 text-sm mt-2">Navigation-grade tri-axis FOG inertial measurement unit for missile guidance and attitude control. Pure solid-state design, high engineering maturity, cost-effective. Full digital RS-422 output.</p>
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="text-xs text-surface-500">{t('products.size')}: 9×9×7.8 cm | RS-422 Output</span>
            </div>
            <div class="flex flex-wrap gap-3 mt-4">
              <span class="tag">Missile Navigation</span><span class="tag">Guided Bombs</span><span class="tag">Attitude Control</span><span class="tag">Navigation Guidance</span>
            </div>
            <a href={translatePath('/contact', lang)} class="btn-primary text-sm mt-4">{t('products.requestDatasheet')}</a>
          </div>
        </div>
      </div>

      <!-- LKF-MBG100A -->
      <div class="glass-card overflow-hidden">
        <div class="grid lg:grid-cols-3">
          <div class="lg:col-span-1 bg-surface-900/50 flex items-center justify-center p-6 min-h-[240px]">
            <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/06/6c238c1a6a44426ab7d576c702361d3a.png" alt="LKF-MBG100A Dual Axis MEMS Gyro Combination" class="max-h-[200px] object-contain" loading="lazy" />
          </div>
          <div class="lg:col-span-2 p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-2">
              <span class="tag">{t('home.tech.gyro.tag2')}</span><span class="text-xs text-surface-500 font-mono">LKF-MBG100A</span>
            </div>
            <h3 class="text-xl font-bold text-white">Dual Axis MEMS Gyro Combination</h3>
            <p class="text-surface-400 text-sm mt-2">High-bandwidth, low-latency, low-noise dual-axis MEMS gyro for servo stabilization. 100% localized components. In-situ replacement for flexure gyros. 4KHz sampling, -40°C to +80°C calibrated.</p>
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="text-xs text-surface-500">{t('products.size')}: 21.5×21.5×28 cm | 4KHz Sampling</span>
            </div>
            <div class="flex flex-wrap gap-3 mt-4">
              <span class="tag">Guide Head Stabilization</span><span class="tag">Optoelectronic Pod</span><span class="tag">Servo Control</span><span class="tag">Stable Platforms</span>
            </div>
            <a href={translatePath('/contact', lang)} class="btn-primary text-sm mt-4">{t('products.requestDatasheet')}</a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section class="container-page pb-20">
    <div class="glass-card p-10 text-center">
      <h3 class="text-2xl font-bold text-white">{t('home.cta.title')}</h3>
      <p class="text-surface-400 mt-2">{t('home.cta.subtitle')}</p>
      <a href={translatePath('/contact', lang)} class="btn-primary mt-6 text-base">{t('home.cta.button')} →</a>
    </div>
  </section>
</BaseLayout>
