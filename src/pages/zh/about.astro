---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, translatePath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  currentPath={Astro.url.pathname}
  title={t('nav.about')}
  description={t('about.mission.desc')}
>
  <section class="border-b border-surface-800/30">
    <div class="container-page py-16 sm:py-20">
      <div class="tag mb-4">{t('footer.aboutUs')}</div>
      <h1 class="text-4xl font-extrabold tracking-tight">
        Technology Driven, <span class="text-gradient">{t('footer.motto').split(' ').slice(-1)}</span>
      </h1>
      <p class="text-surface-400 text-lg mt-4 max-w-2xl">
        HongKong Liocrebif Technology Co., Ltd is a high-tech enterprise specializing in navigation technology, optical devices, and precision machinery.
      </p>
    </div>
  </section>

  <!-- Mission / Vision / Values -->
  <section class="container-page py-16 sm:py-20">
    <div class="grid md:grid-cols-3 gap-8">
      <div class="glass-card p-8 text-center">
        <div class="w-14 h-14 rounded-xl gradient-brand flex items-center justify-center mx-auto mb-5 text-white text-xl shadow-lg shadow-brand-500/20">🎯</div>
        <h3 class="text-xl font-bold text-white mb-3">{t('about.mission.title')}</h3>
        <p class="text-surface-400 text-sm leading-relaxed">
          {t('about.mission.desc')}
        </p>
      </div>
      <div class="glass-card p-8 text-center">
        <div class="w-14 h-14 rounded-xl gradient-brand flex items-center justify-center mx-auto mb-5 text-white text-xl shadow-lg shadow-brand-500/20">🔭</div>
        <h3 class="text-xl font-bold text-white mb-3">{t('about.vision.title')}</h3>
        <p class="text-surface-400 text-sm leading-relaxed">
          {t('about.vision.desc')}
        </p>
      </div>
      <div class="glass-card p-8 text-center">
        <div class="w-14 h-14 rounded-xl gradient-brand flex items-center justify-center mx-auto mb-5 text-white text-xl shadow-lg shadow-brand-500/20">⚙️</div>
        <h3 class="text-xl font-bold text-white mb-3">{t('about.approach.title')}</h3>
        <p class="text-surface-400 text-sm leading-relaxed">
          {t('about.approach.desc')}
        </p>
      </div>
    </div>
  </section>

  <!-- Story Timeline -->
  <section class="border-t border-surface-800/30 bg-surface-900/30">
    <div class="container-page py-16 sm:py-20">
      <h2 class="section-title mb-12">{t('about.timeline.title')}</h2>

      <div class="space-y-8">
        <div class="flex gap-6">
          <div class="hidden sm:block w-20 text-right flex-shrink-0">
            <div class="text-brand-400 font-mono font-bold">2019</div>
          </div>
          <div class="relative flex-shrink-0 flex flex-col items-center">
            <div class="w-3 h-3 rounded-full gradient-brand shadow-lg shadow-brand-500/30"></div>
            <div class="w-px flex-1 bg-surface-700/50 mt-2"></div>
          </div>
          <div class="pb-8">
            <div class="sm:hidden text-brand-400 font-mono font-bold text-sm mb-1">2019</div>
            <h3 class="text-lg font-bold text-white">Company Founded</h3>
            <p class="text-surface-400 text-sm mt-1">HongKong Liocrebif Technology Co., Ltd established with a focus on inertial navigation and fiber optic sensing technology.</p>
          </div>
        </div>

        <div class="flex gap-6">
          <div class="hidden sm:block w-20 text-right flex-shrink-0">
            <div class="text-brand-400 font-mono font-bold">2020</div>
          </div>
          <div class="relative flex-shrink-0 flex flex-col items-center">
            <div class="w-3 h-3 rounded-full gradient-brand shadow-lg shadow-brand-500/30"></div>
            <div class="w-px flex-1 bg-surface-700/50 mt-2"></div>
          </div>
          <div class="pb-8">
            <div class="sm:hidden text-brand-400 font-mono font-bold text-sm mb-1">2020</div>
            <h3 class="text-lg font-bold text-white">Core Technology Development</h3>
            <p class="text-surface-400 text-sm mt-1">Established in-house FOG and MEMS gyroscope R&D capabilities. Built the core team of inertial navigation experts.</p>
          </div>
        </div>

        <div class="flex gap-6">
          <div class="hidden sm:block w-20 text-right flex-shrink-0">
            <div class="text-brand-400 font-mono font-bold">2022</div>
          </div>
          <div class="relative flex-shrink-0 flex flex-col items-center">
            <div class="w-3 h-3 rounded-full gradient-brand shadow-lg shadow-brand-500/30"></div>
            <div class="w-px flex-1 bg-surface-700/50 mt-2"></div>
          </div>
          <div class="pb-8">
            <div class="sm:hidden text-brand-400 font-mono font-bold text-sm mb-1">2022</div>
            <h3 class="text-lg font-bold text-white">Industrial Park & Production Scale-Up</h3>
            <p class="text-surface-400 text-sm mt-1">Established 13,300㎡ self-owned Optoelectronic Industrial Park with full production lines covering components, sensors, and systems.</p>
          </div>
        </div>

        <div class="flex gap-6">
          <div class="hidden sm:block w-20 text-right flex-shrink-0">
            <div class="text-brand-400 font-mono font-bold">2024</div>
          </div>
          <div class="relative flex-shrink-0 flex flex-col items-center">
            <div class="w-3 h-3 rounded-full gradient-brand"></div>
          </div>
          <div>
            <div class="sm:hidden text-brand-400 font-mono font-bold text-sm mb-1">2024</div>
            <h3 class="text-lg font-bold text-white">Global Expansion</h3>
            <p class="text-surface-400 text-sm mt-1">Products now serving 30+ countries. Continued investment in next-generation navigation technology and international partnerships.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Facility -->
  <section class="container-page py-16 sm:py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="section-title">{t('about.facility.title')}</h2>
        <p class="text-surface-400 mt-4 leading-relaxed">
          {t('about.facility.desc')}
        </p>
        <div class="grid grid-cols-2 gap-4 mt-6">
          <div class="glass-card p-4">
            <div class="data-number text-xl">13,300<span class="text-brand-400 text-base">㎡</span></div>
            <div class="text-xs text-surface-500 mt-1">{t('home.stat.park')}</div>
          </div>
          <div class="glass-card p-4">
            <div class="data-number text-xl">50+</div>
            <div class="text-xs text-surface-500 mt-1">{t('home.stat.team')}</div>
          </div>
          <div class="glass-card p-4">
            <div class="data-number text-xl">30+</div>
            <div class="text-xs text-surface-500 mt-1">{t('home.stat.countries')}</div>
          </div>
          <div class="glass-card p-4">
            <div class="data-number text-xl">24/7</div>
            <div class="text-xs text-surface-500 mt-1">Technical Support</div>
          </div>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-square rounded-2xl bg-gradient-to-br from-surface-800 to-surface-900 border border-surface-700/30 flex items-center justify-center overflow-hidden">
          <div class="text-center p-8">
            <div class="text-7xl mb-4">🏭</div>
            <div class="text-2xl font-bold text-white">Optoelectronic</div>
            <div class="text-2xl font-bold text-white">{t('home.stat.park')}</div>
            <div class="text-surface-500 mt-4 text-sm">{t('home.diff.rd')} · {t('home.diff.production')} · {t('home.diff.calibration')}</div>
          </div>
        </div>
        <div class="absolute -bottom-3 -right-3 w-28 h-28 rounded-2xl gradient-brand opacity-10 blur-xl"></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="container-page pb-20">
    <div class="glass-card p-10 text-center">
      <h3 class="text-2xl font-bold text-white">{t('home.cta.title')}</h3>
      <p class="text-surface-400 mt-2">{t('home.cta.subtitle')}</p>
      <a href={translatePath('/contact', lang)} class="btn-primary mt-6 text-base">{t('home.cta.button')} →</a>
    </div>
  </section>
</BaseLayout>
