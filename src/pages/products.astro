---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  currentPath="/products"
  title="Products — Inertial Navigation, Gyroscopes & Fiber Optic Systems"
  description="Explore Liocrebif's complete portfolio: FOG & MEMS gyroscopes, inertial navigation systems, IMUs, north seekers, fiber coil winding machines, and calibration equipment."
>
  <section class="border-b border-surface-800/30">
    <div class="container-page py-16 sm:py-20">
      <div class="tag mb-4">Products</div>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight">Our <span class="text-gradient">Product Lines</span></h1>
      <p class="text-surface-400 text-lg mt-4 max-w-2xl">From core optical components to complete navigation systems — vertically integrated manufacturing.</p>
    </div>
  </section>

  <section class="container-page py-16 sm:py-20 space-y-14">

    <!-- INS -->
    <div class="grid lg:grid-cols-5 gap-8 items-start">
      <div class="lg:col-span-2">
        <div class="w-12 h-12 rounded-xl gradient-brand flex items-center justify-center mb-4 text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"/></svg>
        </div>
        <h2 class="text-2xl font-bold text-white mb-3">Inertial Navigation Systems</h2>
        <p class="text-surface-400 text-sm leading-relaxed mb-4">Tactical-grade FOG and MEMS-based GNSS/INS solutions. Continuous position, velocity, and attitude in GPS-denied and high-dynamic environments.</p>
        <div class="flex flex-wrap gap-2 mb-5">
          <span class="tag">FOG INS</span><span class="tag">MEMS INS</span><span class="tag">North Seeker</span><span class="tag">GNSS/INS</span>
        </div>
        <a href="/products/inertial-navigation-systems" class="btn-outline text-sm">View 3 Products →</a>
      </div>
      <div class="lg:col-span-3 grid sm:grid-cols-2 gap-4">
        <div class="glass-card p-4 flex items-center gap-3">
          <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/01/9916fd75af594a13b9785080e2784c4c.png" alt="LKF-FS300" class="w-14 h-14 object-contain rounded-lg bg-surface-900/50" loading="lazy" />
          <div>
            <div class="text-xs text-surface-500 font-mono">LKF-FS300</div>
            <h4 class="text-white font-semibold text-sm">FOG Integrated Navigation System</h4>
            <p class="text-surface-400 text-xs mt-0.5">Tactical-grade GNSS/INS</p>
          </div>
        </div>
        <div class="glass-card p-4 flex items-center gap-3">
          <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/07/d6d76718798c4d3896e8cad69a483aca.png" alt="LKF-MG300K" class="w-14 h-14 object-contain rounded-lg bg-surface-900/50" loading="lazy" />
          <div>
            <div class="text-xs text-surface-500 font-mono">LKF-MG300K</div>
            <h4 class="text-white font-semibold text-sm">Microminiature MEMS North Seeker</h4>
            <p class="text-surface-400 text-xs mt-0.5">GPS-independent heading</p>
          </div>
        </div>
        <div class="glass-card p-4 flex items-center gap-3">
          <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/07/03e2fdf743744e00b8f04cec5c8a1cc2.png" alt="LKF-MG204B" class="w-14 h-14 object-contain rounded-lg bg-surface-900/50" loading="lazy" />
          <div>
            <div class="text-xs text-surface-500 font-mono">LKF-MG204B</div>
            <h4 class="text-white font-semibold text-sm">Medium Precision MEMS IMU</h4>
            <p class="text-surface-400 text-xs mt-0.5">STIM300 in-situ replacement</p>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-surface-800/30"></div>

    <!-- Gyros -->
    <div class="grid lg:grid-cols-5 gap-8 items-start">
      <div class="lg:col-span-2">
        <div class="w-12 h-12 rounded-xl gradient-brand flex items-center justify-center mb-4 text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <h2 class="text-2xl font-bold text-white mb-3">Gyroscope Systems</h2>
        <p class="text-surface-400 text-sm leading-relaxed mb-4">Single to tri-axis FOG and MEMS gyroscopes. Closed-loop FOG technology with 135μm thin PM fiber, plus high-bandwidth MEMS gyro combinations.</p>
        <div class="flex flex-wrap gap-2 mb-5">
          <span class="tag">FOG</span><span class="tag">MEMS Gyro</span><span class="tag">Dual-Axis</span><span class="tag">Tri-Axis</span>
        </div>
        <a href="/products/gyroscopes" class="btn-outline text-sm">View 4 Products →</a>
      </div>
      <div class="lg:col-span-3 grid sm:grid-cols-2 gap-4">
        <div class="glass-card p-4 flex items-center gap-3">
          <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/10/30/b17433d3ad3d413380bbdb2ed6a5c43e.png" alt="LKF-FS60" class="w-14 h-14 object-contain rounded-lg bg-surface-900/50" loading="lazy" />
          <div><div class="text-xs text-surface-500 font-mono">LKF-FS60</div><h4 class="text-white font-semibold text-sm">Medium-High Precision FOG</h4></div>
        </div>
        <div class="glass-card p-4 flex items-center gap-3">
          <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/26/86c40da8a47542398ab60942bda42052.png" alt="LKF-FS50A/X" class="w-14 h-14 object-contain rounded-lg bg-surface-900/50" loading="lazy" />
          <div><div class="text-xs text-surface-500 font-mono">LKF-FS50A/X</div><h4 class="text-white font-semibold text-sm">Medium-Low Precision FOG</h4></div>
        </div>
        <div class="glass-card p-4 flex items-center gap-3">
          <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/10/31/615113fbaf064eb197b770d9ec6da6e2.png" alt="LKF-F3X90" class="w-14 h-14 object-contain rounded-lg bg-surface-900/50" loading="lazy" />
          <div><div class="text-xs text-surface-500 font-mono">LKF-F3X90</div><h4 class="text-white font-semibold text-sm">Tri-Axis High Precision FOG</h4></div>
        </div>
        <div class="glass-card p-4 flex items-center gap-3">
          <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/06/6c238c1a6a44426ab7d576c702361d3a.png" alt="LKF-MBG100A" class="w-14 h-14 object-contain rounded-lg bg-surface-900/50" loading="lazy" />
          <div><div class="text-xs text-surface-500 font-mono">LKF-MBG100A</div><h4 class="text-white font-semibold text-sm">Dual Axis MEMS Gyro</h4></div>
        </div>
      </div>
    </div>

    <div class="border-t border-surface-800/30"></div>

    <!-- Fiber -->
    <div class="grid lg:grid-cols-5 gap-8 items-start">
      <div class="lg:col-span-2">
        <div class="w-12 h-12 rounded-xl gradient-brand flex items-center justify-center mb-4 text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
        </div>
        <h2 class="text-2xl font-bold text-white mb-3">Fiber Optic Systems</h2>
        <p class="text-surface-400 text-sm leading-relaxed mb-4">FOG components, coil winding machines, and calibration equipment. Complete infrastructure for fiber optic gyroscope production — all in-house.</p>
        <a href="/products/fiber-optic" class="btn-outline text-sm">View 3 Products →</a>
      </div>
      <div class="lg:col-span-3 grid sm:grid-cols-2 gap-4">
        <div class="glass-card p-4 flex items-center gap-3">
          <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/01/7c8932c0c3be441e86c1435ed082538f.jpg" alt="LKF-RH16" class="w-14 h-14 object-contain rounded-lg bg-surface-900/50" loading="lazy" />
          <div><div class="text-xs text-surface-500 font-mono">LKF-RH16</div><h4 class="text-white font-semibold text-sm">Multi-Pole Coil Winding Machine</h4></div>
        </div>
        <div class="glass-card p-4 flex items-center gap-3">
          <div class="w-14 h-14 rounded-lg gradient-brand flex items-center justify-center text-white text-lg">⚙️</div>
          <div><div class="text-xs text-surface-500 font-mono">FOG Series</div><h4 class="text-white font-semibold text-sm">FOG Components</h4></div>
        </div>
        <div class="glass-card p-4 flex items-center gap-3">
          <div class="w-14 h-14 rounded-lg gradient-brand flex items-center justify-center text-white text-lg">📐</div>
          <div><div class="text-xs text-surface-500 font-mono">Calibration</div><h4 class="text-white font-semibold text-sm">Measuring & Calibration Equipment</h4></div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page pb-20">
    <div class="glass-card p-10 text-center">
      <h3 class="text-2xl font-bold text-white">Not sure which product fits your needs?</h3>
      <p class="text-surface-400 mt-2">Our engineering team can help you find the right solution.</p>
      <a href="/contact" class="btn-primary mt-6 text-base">Contact Our Engineers →</a>
    </div>
  </section>
</BaseLayout>
