---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  currentPath="/products/inertial-navigation-systems"
  title="Inertial Navigation Systems — FOG & MEMS INS/GNSS"
  description="Tactical-grade FOG and MEMS inertial navigation systems. GNSS/INS integrated solutions for aircraft, UAV, marine, and autonomous vehicles."
>
  <section class="border-b border-surface-800/30">
    <div class="container-page py-16 sm:py-20">
      <a href="/products" class="text-surface-500 hover:text-surface-300 text-sm transition-colors mb-4 inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> All Products
      </a>
      <h1 class="text-4xl font-extrabold tracking-tight">Inertial <span class="text-gradient">Navigation Systems</span></h1>
      <p class="text-surface-400 text-lg mt-4 max-w-2xl">Tactical-grade integrated navigation solutions delivering continuous position, velocity, and attitude — even in GPS-denied environments.</p>
    </div>
  </section>

  <section class="container-page py-16">
    <div class="space-y-10">

      <!-- LKF-FS300 -->
      <div class="glass-card overflow-hidden">
        <div class="grid lg:grid-cols-3">
          <div class="lg:col-span-1 bg-surface-900/50 flex items-center justify-center p-6 min-h-[240px]">
            <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/01/9916fd75af594a13b9785080e2784c4c.png" alt="LKF-FS300 Fiber Optical Integrated Navigation System" class="max-h-[200px] object-contain" loading="lazy" />
          </div>
          <div class="lg:col-span-2 p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-2">
              <span class="tag">FOG INS</span><span class="text-xs text-surface-500 font-mono">LKF-FS300</span>
            </div>
            <h3 class="text-xl font-bold text-white">Fiber Optical Integrated Navigation System</h3>
            <p class="text-surface-400 text-sm mt-2">Tactical-grade GNSS/INS system with high-precision closed-loop FOG and accelerometer. Self-alignment capability, RTK high-precision navigation. Internal vibration damping design with EMI protection.</p>
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="text-xs text-surface-500">Size: 21.2×15.5×12.5 cm</span>
            </div>
            <div class="flex flex-wrap gap-3 mt-4">
              <span class="tag">Aircraft Navigation</span><span class="tag">UAV/Vehicle/Ship</span><span class="tag">Attitude Reference</span>
            </div>
            <a href="/contact" class="btn-primary text-sm mt-4">Request Datasheet</a>
          </div>
        </div>
      </div>

      <!-- LKF-MG300K -->
      <div class="glass-card overflow-hidden">
        <div class="grid lg:grid-cols-3">
          <div class="lg:col-span-1 bg-surface-900/50 flex items-center justify-center p-6 min-h-[240px]">
            <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/07/d6d76718798c4d3896e8cad69a483aca.png" alt="LKF-MG300K Microminiature MEMS North Seeker" class="max-h-[200px] object-contain" loading="lazy" />
          </div>
          <div class="lg:col-span-2 p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-2">
              <span class="tag">North Seeker</span><span class="text-xs text-surface-500 font-mono">LKF-MG300K</span>
            </div>
            <h3 class="text-xl font-bold text-white">Microminiature MEMS North Seeker</h3>
            <p class="text-surface-400 text-sm mt-2">Six-axis MEMS inertial sensor combo for north-seeking, navigation and attitude control. Full temperature compensation (-45°C to +80°C), 4KHz high-speed sampling, vibration-resistant sealed design.</p>
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="text-xs text-surface-500">Size: 4.7×4.7×3.15 cm</span>
            </div>
            <div class="flex flex-wrap gap-3 mt-4">
              <span class="tag">North Seeking</span><span class="tag">Drilling Systems</span><span class="tag">Vehicle/Vessel Attitude</span><span class="tag">Satcom on-the-Move</span>
            </div>
            <a href="/contact" class="btn-primary text-sm mt-4">Request Datasheet</a>
          </div>
        </div>
      </div>

      <!-- LKF-MG204B -->
      <div class="glass-card overflow-hidden">
        <div class="grid lg:grid-cols-3">
          <div class="lg:col-span-1 bg-surface-900/50 flex items-center justify-center p-6 min-h-[240px]">
            <img src="https://cowork-storage-public-cdn.lx.netease.com/lxbg/2024/11/07/03e2fdf743744e00b8f04cec5c8a1cc2.png" alt="LKF-MG204B Medium Precision MEMS IMU" class="max-h-[200px] object-contain" loading="lazy" />
          </div>
          <div class="lg:col-span-2 p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-2">
              <span class="tag">MEMS IMU</span><span class="text-xs text-surface-500 font-mono">LKF-MG204B</span>
            </div>
            <h3 class="text-xl font-bold text-white">Medium Precision MEMS Inertial Measurement Unit</h3>
            <p class="text-surface-400 text-sm mt-2">Six-axis MEMS inertial attitude system with full-temperature calibration. In-situ replacement for STIM300. 1KHz sampling, sealed design for harsh environments. High-performance gyro + accelerometer integration.</p>
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="text-xs text-surface-500">Size: 4.48×3.86×2.15 cm</span>
            </div>
            <div class="flex flex-wrap gap-3 mt-4">
              <span class="tag">UAV Attitude Reference</span><span class="tag">Mobile Mapping</span><span class="tag">Missile Flight Control</span><span class="tag">Radar Stabilization</span>
            </div>
            <a href="/contact" class="btn-primary text-sm mt-4">Request Datasheet</a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section class="container-page pb-20">
    <div class="glass-card p-10 text-center">
      <h3 class="text-2xl font-bold text-white">Need a custom navigation solution?</h3>
      <p class="text-surface-400 mt-2">We configure hardware and software to your requirements.</p>
      <a href="/contact" class="btn-primary mt-6 text-base">Contact Our Engineers →</a>
    </div>
  </section>
</BaseLayout>
