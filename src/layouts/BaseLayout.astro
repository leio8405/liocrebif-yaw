---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, translatePath, type Lang } from '../i18n/utils';

export interface Props {
  title: string;
  description: string;
  currentPath?: string;
}

const { title, description, currentPath = '/' } = Astro.props;
const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function isActive(path: string) {
  // Strip /zh prefix for comparison
  const normalizedPath = currentPath.replace(/^\/zh/, '') || '/';
  const normalizedTarget = path;
  if (normalizedTarget === '/') return normalizedPath === '/';
  return normalizedPath.startsWith(normalizedTarget);
}

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Liocrebif Technology</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="alternate" hreflang="en" href={`https://www.liocrebif-yaw.top${translatePath(currentPath, 'en')}`} />
  <link rel="alternate" hreflang="zh-CN" href={`https://www.liocrebif-yaw.top${translatePath(currentPath, 'zh')}`} />
  <link rel="alternate" hreflang="x-default" href={`https://www.liocrebif-yaw.top${translatePath(currentPath, 'en')}`} />
</head>
<body class="min-h-screen flex flex-col antialiased">
  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-surface-950/80 backdrop-blur-md border-b border-surface-800/50">
    <nav class="container-page flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={translatePath('/', lang)} class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-lg gradient-brand flex items-center justify-center text-white font-bold text-sm shadow-lg shadow-brand-500/20">L</div>
        <div>
          <div class="text-white font-bold text-sm tracking-tight">LIOCREBIF</div>
          <div class="text-surface-500 text-[10px] tracking-widest uppercase">Yaw Technology</div>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-8">
        <a href={translatePath('/', lang)} class={isActive('/') ? 'nav-link nav-link-active' : 'nav-link'}>{t('nav.home')}</a>
        <div class="relative group">
          <a href={translatePath('/products', lang)} class={isActive('/products') ? 'nav-link nav-link-active flex items-center gap-1' : 'nav-link flex items-center gap-1'}>
            {t('nav.products')}
            <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="glass-card p-2 min-w-[240px]">
              <a href={translatePath('/products/inertial-navigation-systems', lang)} class="block px-4 py-2.5 rounded-lg text-sm text-surface-300 hover:text-white hover:bg-surface-700/50 transition-colors">{t('nav.ins')}</a>
              <a href={translatePath('/products/gyroscopes', lang)} class="block px-4 py-2.5 rounded-lg text-sm text-surface-300 hover:text-white hover:bg-surface-700/50 transition-colors">{t('nav.gyroscopes')}</a>
              <a href={translatePath('/products/fiber-optic', lang)} class="block px-4 py-2.5 rounded-lg text-sm text-surface-300 hover:text-white hover:bg-surface-700/50 transition-colors">{t('nav.fiberOptic')}</a>
              <div class="border-t border-surface-700/50 my-1"></div>
              <a href={translatePath('/products', lang)} class="block px-4 py-2.5 rounded-lg text-sm text-brand-400 hover:text-brand-300 transition-colors">{t('nav.viewAll')}</a>
            </div>
          </div>
        </div>
        <a href={translatePath('/about', lang)} class={isActive('/about') ? 'nav-link nav-link-active' : 'nav-link'}>{t('nav.about')}</a>
        <a href={translatePath('/contact', lang)} class={isActive('/contact') ? 'nav-link nav-link-active' : 'nav-link'}>{t('nav.contact')}</a>
      </div>

      <!-- CTA + Language Switcher + Mobile Toggle -->
      <div class="flex items-center gap-3">
        <!-- Language Switcher -->
        <div class="hidden sm:flex items-center gap-1 text-xs">
          <a href={translatePath(currentPath, 'en')} class={`px-1.5 py-0.5 rounded ${lang === 'en' ? 'text-white bg-surface-700' : 'text-surface-500 hover:text-white'}`}>EN</a>
          <span class="text-surface-700">|</span>
          <a href={translatePath(currentPath, 'zh')} class={`px-1.5 py-0.5 rounded ${lang === 'zh' ? 'text-white bg-surface-700' : 'text-surface-500 hover:text-white'}`}>中</a>
        </div>
        <a href={translatePath('/contact', lang)} class="hidden sm:inline-flex btn-primary text-sm !py-2 !px-4">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          {t('nav.inquiry')}
        </a>
        <button id="mobile-menu-btn" class="lg:hidden p-2 text-surface-300 hover:text-white" aria-label="Menu">
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden hidden border-t border-surface-800/50 bg-surface-900/95 backdrop-blur-md">
      <div class="container-page py-4 space-y-1">
        <a href={translatePath('/', lang)} class={isActive('/') ? 'block px-4 py-3 rounded-lg text-white font-medium bg-surface-800/50' : 'block px-4 py-3 rounded-lg text-surface-300 hover:text-white hover:bg-surface-800/50 transition-colors'}>{t('nav.home')}</a>
        <a href={translatePath('/products', lang)} class={isActive('/products') ? 'block px-4 py-3 rounded-lg text-white font-medium bg-surface-800/50' : 'block px-4 py-3 rounded-lg text-surface-300 hover:text-white hover:bg-surface-800/50 transition-colors'}>{t('nav.products')}</a>
        <a href={translatePath('/products/inertial-navigation-systems', lang)} class={isActive('/products/inertial-navigation-systems') ? 'block px-8 py-2 rounded-lg text-white text-sm bg-surface-800/50' : 'block px-8 py-2 rounded-lg text-surface-400 text-sm hover:text-white hover:bg-surface-800/50 transition-colors'}>↳ {t('nav.ins')}</a>
        <a href={translatePath('/products/gyroscopes', lang)} class={isActive('/products/gyroscopes') ? 'block px-8 py-2 rounded-lg text-white text-sm bg-surface-800/50' : 'block px-8 py-2 rounded-lg text-surface-400 text-sm hover:text-white hover:bg-surface-800/50 transition-colors'}>↳ {t('nav.gyroscopes')}</a>
        <a href={translatePath('/products/fiber-optic', lang)} class={isActive('/products/fiber-optic') ? 'block px-8 py-2 rounded-lg text-white text-sm bg-surface-800/50' : 'block px-8 py-2 rounded-lg text-surface-400 text-sm hover:text-white hover:bg-surface-800/50 transition-colors'}>↳ {t('nav.fiberOptic')}</a>
        <a href={translatePath('/about', lang)} class={isActive('/about') ? 'block px-4 py-3 rounded-lg text-white font-medium bg-surface-800/50' : 'block px-4 py-3 rounded-lg text-surface-300 hover:text-white hover:bg-surface-800/50 transition-colors'}>{t('nav.about')}</a>
        <a href={translatePath('/contact', lang)} class={isActive('/contact') ? 'block px-4 py-3 rounded-lg text-white font-medium bg-surface-800/50' : 'block px-4 py-3 rounded-lg text-surface-300 hover:text-white hover:bg-surface-800/50 transition-colors'}>{t('nav.contact')}</a>
        <div class="pt-3 border-t border-surface-800/50">
          <!-- Mobile Language Switcher -->
          <div class="flex items-center gap-2 px-4 py-2 text-sm">
            <a href={translatePath(currentPath, 'en')} class={`px-3 py-1.5 rounded-lg ${lang === 'en' ? 'text-white bg-surface-700' : 'text-surface-400 hover:text-white'}`}>English</a>
            <a href={translatePath(currentPath, 'zh')} class={`px-3 py-1.5 rounded-lg ${lang === 'zh' ? 'text-white bg-surface-700' : 'text-surface-400 hover:text-white'}`}>中文</a>
          </div>
          <a href={translatePath('/contact', lang)} class="btn-primary w-full justify-center text-sm mt-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {t('nav.sendInquiry')}
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="flex-1 pt-16">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-surface-800/50 bg-surface-900/50">
    <div class="container-page py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
        <div>
          <div class="flex items-center gap-2.5 mb-4">
            <div class="w-8 h-8 rounded-lg gradient-brand flex items-center justify-center text-white font-bold text-sm">L</div>
            <div>
              <div class="text-white font-bold text-sm">LIOCREBIF</div>
              <div class="text-surface-500 text-[10px] tracking-widest uppercase">Yaw Technology</div>
            </div>
          </div>
          <p class="text-surface-400 text-sm leading-relaxed">{t('footer.tagline')}</p>
          <div class="flex items-center gap-3 mt-5">
            <a href="https://wa.me/8618062673472" class="w-9 h-9 rounded-lg bg-surface-800 flex items-center justify-center text-surface-400 hover:text-green-400 hover:bg-surface-700 transition-all" aria-label="WhatsApp" target="_blank">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
            </a>
            <a href="mailto:yaw_chan@liocrebif.com.cn" class="w-9 h-9 rounded-lg bg-surface-800 flex items-center justify-center text-surface-400 hover:text-brand-400 hover:bg-surface-700 transition-all" aria-label="Email">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </a>
          </div>
        </div>

        <div>
          <h4 class="text-white font-semibold text-sm mb-4 tracking-wide uppercase">{t('footer.products')}</h4>
          <ul class="space-y-2.5">
            <li><a href={translatePath('/products/inertial-navigation-systems', lang)} class="footer-link">{t('nav.ins')}</a></li>
            <li><a href={translatePath('/products/gyroscopes', lang)} class="footer-link">{t('footer.fogGyroscopes')}</a></li>
            <li><a href={translatePath('/products/fiber-optic', lang)} class="footer-link">{t('nav.fiberOptic')}</a></li>
            <li><a href={translatePath('/products/inertial-navigation-systems', lang)} class="footer-link">{t('footer.memsNorthSeeker')}</a></li>
            <li><a href={translatePath('/products/inertial-navigation-systems', lang)} class="footer-link">{t('footer.imuIns')}</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-white font-semibold text-sm mb-4 tracking-wide uppercase">{t('footer.company')}</h4>
          <ul class="space-y-2.5">
            <li><a href={translatePath('/about', lang)} class="footer-link">{t('footer.aboutUs')}</a></li>
            <li><a href={translatePath('/contact', lang)} class="footer-link">{t('footer.contact')}</a></li>
            <li><a href={translatePath('/products', lang)} class="footer-link">{t('footer.allProducts')}</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-white font-semibold text-sm mb-4 tracking-wide uppercase">{t('footer.contact')}</h4>
          <ul class="space-y-2.5">
            <li class="text-surface-400 text-sm">Office Unit B ON 9/F</li>
            <li class="text-surface-400 text-sm">Thomson Commercial Building</li>
            <li class="text-surface-400 text-sm">8 Thomson Road, Hong Kong</li>
            <li class="mt-2"><a href="mailto:yaw_chan@liocrebif.com.cn" class="footer-link font-mono text-xs">yaw_chan@liocrebif.com.cn</a></li>
            <li><a href="tel:+8618062673472" class="footer-link font-mono text-xs">+86 180 6267 3472</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-surface-800/50 mt-12 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-surface-500 text-xs">&copy; {currentYear} HongKong Liocrebif Technology Co., Ltd. All rights reserved.</p>
        <p class="text-surface-600 text-xs">{t('footer.motto')}</p>
      </div>
    </div>
  </footer>

  <!-- Floating Buttons -->
  <div class="fixed bottom-6 right-6 z-50 flex flex-col gap-3">
    <a href="https://wa.me/8618062673472" class="w-12 h-12 rounded-full bg-green-500 text-white flex items-center justify-center shadow-lg shadow-green-500/30 hover:bg-green-400 transition-all hover:scale-110" aria-label="WhatsApp" target="_blank">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
    </a>
    <a href="mailto:yaw_chan@liocrebif.com.cn" class="w-12 h-12 rounded-full bg-brand-600 text-white flex items-center justify-center shadow-lg shadow-brand-600/30 hover:bg-brand-500 transition-all hover:scale-110" aria-label="Email">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
    </a>
  </div>
</body>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
</html>
